// verifybamid-py HPC pipeline config

params {
    // inputs
    samples     = "data/sample_list.tsv"
    ref         = "/home/ottov/ref/hg38/GRCh38_full_analysis_set_plus_decoy_hla.fa"
    bindir      = "/home/ottov/VSCodeProjects/verifybamid-modernize/verifybamid-py/.venv/bin"

    // outputs / caches
    outdir      = "results"
    panel_cache = "panels"          // persistent storeDir for built panels + chip matrices

    // mode
    fast        = true              // downsampled panel + targeted fetch (S3-egress saver)
    fast_n      = 20000
    min_maf     = 0.10
    // Per-fetch genomic-span cap. Measured egress sweep (chr20+chr21, bytes off the
    // NIC) shows 1M is the EGRESS minimum, not just the fastest: tighter spans (5k-100k)
    // cost MORE bytes because neighbouring markers fall into separate fetches that each
    // re-download the same overlapping CRAM slice (htslib can't sub-fetch below a slice).
    // Wider grouping de-dups those slice reads; uncapped then rises again (pulls
    // marker-free gaps). So 1M minimises both bytes and wall time -- do not lower it.
    // NOTE: even at the optimum, fast mode pulls ~13-15 GB of an ~19 GB CRAM (markers are
    // ~155 kb apart genome-wide, so you touch most slices). The real egress lever is
    // fast_n, but it's strongly sub-linear (20k->5k saves only ~30%). See README.
    max_span    = 1000000
    chipmix     = true              // compute CHIPMIX from the project genotype VCF
    best        = false             // optional: best-match identity / sample-swap check

    // per-sample SLURM resources.
    // Scaling is ~linear, so CPU-hours/sample is ~flat regardless of cpus -> for a
    // fixed slot budget, throughput is set by total slots, NOT cpus-per-sample.
    // Prefer FEW cores x MANY concurrent samples: less idle reservation during the
    // serial tail (panel load / parquet write / estimate), better queue packing,
    // smaller blast radius on failure, fewer concurrent S3 streams. 2-4 is the
    // sweet spot for a big batch; raise only to cut a single sample's latency.
    cpus        = 2
    mem         = '6 GB'
    time        = '4h'

    // Max CRAMs streaming CONCURRENTLY (maxForks on VERIFYBAMID). This is the S3
    // throttle knob, NOT cpus and NOT queueSize. Measured: the HPC->S3 WAN saturates
    // (~600 Mbit/s) at a handful of streams, and a single sample already silently
    // under-reads at ~32 connections. Aggregate connections = max_streams x cpus, so
    // 8 x 2 = 16 stayed at coverage 1.000 while 32 collapsed to 0.40. Raise sharply
    // when running IN-REGION (no WAN ceiling); lower if you still see coverage-guard
    // retries. The coverage guard + retry is the safety net if this is set too high.
    max_streams = 8

    region      = "us-east-1"
    // Presigned-URL lifetime (s). Presign happens at task START, so queue wait does
    // not consume it -- only the sample's own runtime does. 6h leaves headroom for a
    // slow/contended stream; a too-short value 403s on late range-fetches mid-pileup.
    presign_expires = 21600
}

process {
    executor = 'slurm'
    queue    = 'defaultq'
}

executor {
    // Overall ceiling on jobs submitted to SLURM. The per-sample S3-stream throttle
    // is params.max_streams (maxForks on VERIFYBAMID), NOT this -- queueSize only
    // caps total slot pressure on the scheduler.
    queueSize    = 200
    submitRateLimit = '20/1min'
}

profiles {
    // run everything on the local node instead of submitting to SLURM (testing)
    local { process.executor = 'local' }
    slurm { process.executor = 'slurm'; process.queue = 'defaultq' }
}

// keep AWS region visible to tasks (presign + streaming). The CA bundle for
// pysam's libcurl is auto-detected per-distro by open_cram(); override here only
// if your nodes keep certs in a nonstandard location.
env {
    AWS_REGION = params.region
}

report  { enabled = true; file = "${params.outdir}/_report.html";  overwrite = true }
timeline{ enabled = true; file = "${params.outdir}/_timeline.html"; overwrite = true }
trace   { enabled = true; file = "${params.outdir}/_trace.txt";     overwrite = true }
