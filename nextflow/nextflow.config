// verifybamid-py HPC pipeline config

params {
    // inputs
    samples     = "data/sample_list.tsv"
    ref         = "/home/ottov/ref/hg38/GRCh38_full_analysis_set_plus_decoy_hla.fa"
    bindir      = "/home/ottov/VSCodeProjects/verifybamid-modernize/verifybamid-py/.venv/bin"

    // outputs / caches
    outdir      = "results"
    panel_cache = "panels"          // persistent storeDir for built panels + chip matrices

    // mode
    fast        = true              // downsampled panel + targeted fetch (S3-egress saver)
    fast_n      = 20000
    min_maf     = 0.10
    // Per-fetch genomic-span cap. Node/WAN sweep (jobs=8): 150k/1M/10M all ~280-330s
    // (flat), uncapped ~390s (don't read whole-genome spans). 1M is nominally fastest
    // AND issues ~6x fewer S3 requests/sample (20k -> 3.3k) -> more throttle margin at
    // fleet scale; costs slightly more egress. Drop to 150k to minimise egress bytes.
    max_span    = 1000000
    chipmix     = true              // compute CHIPMIX from the project genotype VCF
    best        = false             // optional: best-match identity / sample-swap check

    // per-sample SLURM resources.
    // Scaling is ~linear, so CPU-hours/sample is ~flat regardless of cpus -> for a
    // fixed slot budget, throughput is set by total slots, NOT cpus-per-sample.
    // Prefer FEW cores x MANY concurrent samples: less idle reservation during the
    // serial tail (panel load / parquet write / estimate), better queue packing,
    // smaller blast radius on failure, fewer concurrent S3 streams. 2-4 is the
    // sweet spot for a big batch; raise only to cut a single sample's latency.
    cpus        = 2
    mem         = '6 GB'
    time        = '4h'

    region      = "us-east-1"
}

process {
    executor = 'slurm'
    queue    = 'defaultq'
}

executor {
    queueSize    = 200              // max concurrent SLURM jobs in flight
    submitRateLimit = '20/1min'
}

profiles {
    // run everything on the local node instead of submitting to SLURM (testing)
    local { process.executor = 'local' }
    slurm { process.executor = 'slurm'; process.queue = 'defaultq' }
}

// keep AWS region visible to tasks (presign + streaming). The CA bundle for
// pysam's libcurl is auto-detected per-distro by open_cram(); override here only
// if your nodes keep certs in a nonstandard location.
env {
    AWS_REGION = params.region
}

report  { enabled = true; file = "${params.outdir}/_report.html";  overwrite = true }
timeline{ enabled = true; file = "${params.outdir}/_timeline.html"; overwrite = true }
trace   { enabled = true; file = "${params.outdir}/_trace.txt";     overwrite = true }
